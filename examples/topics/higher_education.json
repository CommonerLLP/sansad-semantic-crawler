    {"tag": "reservation", "label": "Reservation", "weight": 3, "patterns": ["reservation", "reserved\\s+categor", "\\bSC\\b", "\\bST\\b", "\\bOBC\\b", "\\bEWS\\b", "\\bPwBD\\b", "\\bPwD\\b"]},
    {"tag": "mission_mode", "label": "Mission Mode", "patterns": ["Mission\\s+Mode", "Rozgar\\s+Mela", "recruitment\\s+drive"]},
    {"tag": "institution", "label": "Institution-specific", "patterns": ["\\bIIT\\b", "\\bIIM\\b", "\\bNIT\\b", "\\bIIIT\\b", "central\\s+universit", "\\bAIIMS\\b"]},
    {"tag": "ad_hoc", "label": "Ad hoc / contract", "patterns": ["ad[\\s-]?hoc", "contract\\s+faculty"]},
    {"tag": "dereservation", "label": "De-reservation / NFS", "patterns": ["de[-\\s]?reservation", "no\\s+suitable\\s+candidate", "\\bNFS\\b"]}
  ]
}

