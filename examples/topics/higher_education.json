    "reservation": ["SC ST OBC faculty", "reserved category vacancy", "reservation roster", "EWS faculty reservation", "PwBD faculty"],
    "institutions": ["IIT faculty", "IIM faculty", "NIT faculty", "Central University faculty"],
    "recruitment": ["Mission Mode recruitment", "Rozgar Mela faculty", "ad hoc teachers", "de-reservation faculty posts"]
  },
  "lok_sabha_ministries": ["EDUCATION", "HUMAN RESOURCE DEVELOPMENT", "HEALTH AND FAMILY WELFARE"],
